{
  "manifest_version": 3,
  "name": "Amenitiz Translate Extension",
  "version": "1.0",
  "description": "Outil pour traduction sur Amenitiz",
  "permissions": [
    "activeTab", "tabs", "scripting"
  ],
  "background": {
    "service_worker": "./background.js"
  },
  "content_scripts": [
    {
      "js": ["./popup/jquery-3.7.1.min.js", "./jquery.csv.min.js", "./content.js"],
      "matches": ["*://*.amenitiz.io/*"]
    }
  ],
 
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "images/flag_16.png",
      "32": "images/flag_32.png",
      "48": "images/flag_48.png",
      "128": "images/flag_128.png"
    }
  }
}